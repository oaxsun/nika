rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() && request.auth.token.email in [
        'hello@oaxsun.tech'
      ];
    }

    match /programs/{programId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();

      match /weeks/{weekId} {
        allow read: if signedIn();
        allow write: if isAdmin();
      }

      match /sessions/{sessionId} {
        allow read: if signedIn();
        allow write: if isAdmin();
      }
    }

    match /invitations/{code} {
      // La app solo puede consultar un codigo exacto. No permitimos listar codigos desde la app.
      allow get: if true;
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || signedIn();
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();

      match /completedSessions/{sessionId} {
        allow read, write: if isAdmin() || (signedIn() && request.auth.uid == userId);
      }

      match /runs/{runId} {
        allow read, write: if isAdmin() || (signedIn() && request.auth.uid == userId);
      }
    }
  }
}
